    "react-dom": ">=18"
  },
  "dependencies": {
    "clarity-mind": "^0.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
