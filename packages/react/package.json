{
  "name": "@clarity-mind/react",
  "version": "0.1.1",
  "description": "React binding for clarity-mind: an interactive, keyboard-first mind-map component.",
  "keywords": [
    "mind-map",
    "mindmap",
    "react",
    "react-component",
    "diagram",
    "brainstorming"
  ],
  "license": "MIT",
  "author": "udielenberg <udielenberg@users.noreply.github.com>",
  "homepage": "https://github.com/udielenberg/clarity#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/udielenberg/clarity.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/udielenberg/clarity/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
