{
  "name": "clarity-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "clarity — a better-UX, open-source mind-mapping library for the web",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/react",
    "demo"
  ],
  "scripts": {
    "dev": "npm run dev --workspace demo",
    "build": "npm run build --workspace packages/core && npm run build --workspace packages/react && npm run build --workspace demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.check.json && tsc --noEmit -p tsconfig.ui.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^4.1.10"
  }
}
